<div class="relative flex min-h-[calc(100vh-8rem)] items-center justify-center px-4 py-24">
  <div class="relative z-10 w-full max-w-lg animate-scale-up">
    <div class="glass-card overflow-hidden rounded-[3.5rem] p-10 shadow-xl">
      <div class="absolute inset-x-0 top-0 h-1.5 bg-gradient-to-r from-rose-400 via-amber-400 to-sky-400 shadow-sm"></div>

      <header class="mb-12 text-center">
        <div class="mx-auto mb-8 flex h-24 w-24 items-center justify-center rounded-[2rem] bg-rose-100 text-rose-600 shadow-inner ring-1 ring-rose-200">
          <i class="fa-solid fa-shield-halved text-4xl animate-pulse"></i>
        </div>
        <h2 class="text-3xl font-black tracking-tight text-stone-900 uppercase italic md:text-4xl">Nowe zabezpieczenia</h2>
        <p class="mt-4 text-sm font-medium text-stone-600 italic">Zdefiniuj swoje nowe hasło do świata CinemaŚty.</p>
        <div class="mx-auto mt-6 h-1 w-12 rounded-full bg-stone-200"></div>
      </header>

      <form id="newPasswordForm" class="space-y-8">
        <input type="hidden" id="token" value="{{token}}">

        <div class="space-y-6">
          <div class="group relative">
            <span class="absolute inset-y-0 left-0 flex w-16 items-center justify-center text-stone-400 transition-colors group-focus-within:text-rose-500">
              <i class="fa-solid fa-lock text-lg"></i>
            </span>
            <input type="password" id="newPass" required placeholder="Wprowadź nowe hasło"
              class="w-full rounded-2xl border border-stone-200 bg-white py-5 pl-16 pr-6 text-base font-bold text-stone-900 placeholder:text-stone-400 outline-none transition-all focus:border-rose-400 focus:ring-4 focus:ring-rose-100">
          </div>

          <div class="group relative">
            <span class="absolute inset-y-0 left-0 flex w-16 items-center justify-center text-stone-400 transition-colors group-focus-within:text-rose-500">
              <i class="fa-solid fa-check-double text-lg"></i>
            </span>
            <input type="password" id="confirmPass" required placeholder="Powtórz nowe hasło"
              class="w-full rounded-2xl border border-stone-200 bg-white py-5 pl-16 pr-6 text-base font-bold text-stone-900 placeholder:text-stone-400 outline-none transition-all focus:border-rose-400 focus:ring-4 focus:ring-rose-100">
          </div>
        </div>

        <div class="pt-4">
          <button type="submit" class="btn-primary group w-full py-6 text-lg font-black italic tracking-widest active:scale-[0.98]">
            AKTUALIZUJ HASŁO
            <i class="fa-solid fa-arrow-right ml-3 transition-transform group-hover:translate-x-2"></i>
          </button>
        </div>
      </form>

      <footer class="mt-10 text-center">
        <a href="/logowanie" class="text-[10px] font-black uppercase tracking-widest text-stone-500 transition-colors hover:text-rose-600">
          Wróć do logowania
        </a>
      </footer>
    </div>
  </div>
</div>
<script src="/js/auth.js"></script>
