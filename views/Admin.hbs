<div class="relative flex-1 px-4 pb-24 pt-8 md:px-8 md:pt-12">
  <div class="relative z-10 mx-auto max-w-6xl">
    <header class="mb-10 animate-slide-up md:mb-14">
      <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="font-display text-[11px] font-bold uppercase tracking-[0.28em] text-rose-600/90">CinemaŚty — administracja</p>
          <h1 class="mt-3 font-display text-4xl font-black leading-[1.08] tracking-tight text-stone-900 md:text-5xl lg:text-[3.25rem]">
            <span class="bg-gradient-to-r from-stone-900 via-rose-900 to-violet-900 bg-clip-text text-transparent">Panel</span>
            <span class="text-stone-800"> sterowania</span>
          </h1>
          <p class="mt-4 max-w-lg text-base leading-relaxed text-stone-600 md:text-lg">Jedno miejsce na filmy, seanse, sale i rezerwacje. Wybierz moduł poniżej.</p>
        </div>
        <div class="hidden shrink-0 rounded-3xl border border-stone-200/90 bg-white/90 px-6 py-5 text-right shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/60 sm:block">
          <p class="text-[10px] font-bold uppercase tracking-widest text-stone-400">Skrót</p>
          <p class="mt-1 font-display text-sm font-bold text-stone-800">Moduły otwierają się w oknie</p>
          <p class="mt-0.5 text-xs text-stone-500">W tym sale i statystyki</p>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-5 lg:grid-cols-3 lg:gap-6 animate-fade-in" style="animation-delay: 0.08s">
      <div
        id="openMoviesManager"
        class="group relative cursor-pointer overflow-hidden rounded-3xl border border-stone-200/90 bg-white/95 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/50 transition-all duration-300 hover:-translate-y-1 hover:border-rose-200 hover:shadow-xl hover:shadow-rose-200/25 active:scale-[0.99] md:p-7"
      >
        <div class="absolute right-0 top-0 h-24 w-24 translate-x-6 -translate-y-6 rounded-full bg-rose-400/15 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative flex items-start gap-5">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-rose-500 to-rose-600 text-xl text-white shadow-lg shadow-rose-500/35 transition-transform duration-300 group-hover:scale-105">
            <i class="fas fa-film"></i>
          </div>
          <div class="min-w-0 flex-1 pt-0.5">
            <div class="flex items-start justify-between gap-2">
              <h2 class="font-display text-xl font-bold text-stone-900">Filmy</h2>
              <i class="fas fa-arrow-right text-sm text-stone-300 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-rose-500"></i>
            </div>
            <p class="mt-1 text-sm text-stone-500">Katalog, plakaty, zwiastuny i daty emisji.</p>
            <span class="mt-4 inline-flex rounded-full bg-rose-50 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-rose-700 ring-1 ring-rose-100">Baza filmów</span>
          </div>
        </div>
      </div>

      <div
        id="openScreeningsManager"
        class="group relative cursor-pointer overflow-hidden rounded-3xl border border-stone-200/90 bg-white/95 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/50 transition-all duration-300 hover:-translate-y-1 hover:border-violet-200 hover:shadow-xl hover:shadow-violet-200/25 active:scale-[0.99] md:p-7"
      >
        <div class="absolute right-0 top-0 h-24 w-24 translate-x-6 -translate-y-6 rounded-full bg-violet-400/15 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative flex items-start gap-5">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-violet-500 to-violet-700 text-xl text-white shadow-lg shadow-violet-500/35 transition-transform duration-300 group-hover:scale-105">
            <i class="fas fa-calendar-days"></i>
          </div>
          <div class="min-w-0 flex-1 pt-0.5">
            <div class="flex items-start justify-between gap-2">
              <h2 class="font-display text-xl font-bold text-stone-900">Seanse</h2>
              <i class="fas fa-arrow-right text-sm text-stone-300 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-violet-600"></i>
            </div>
            <p class="mt-1 text-sm text-stone-500">Harmonogram, sale i statusy seansów.</p>
            <span class="mt-4 inline-flex rounded-full bg-violet-50 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-violet-800 ring-1 ring-violet-100">Repertuar</span>
          </div>
        </div>
      </div>

      <div
        id="openBookingsManager"
        class="group relative cursor-pointer overflow-hidden rounded-3xl border border-stone-200/90 bg-white/95 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/50 transition-all duration-300 hover:-translate-y-1 hover:border-amber-200 hover:shadow-xl hover:shadow-amber-200/20 active:scale-[0.99] md:p-7"
      >
        <div class="absolute right-0 top-0 h-24 w-24 translate-x-6 -translate-y-6 rounded-full bg-amber-400/15 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative flex items-start gap-5">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-500 to-orange-600 text-xl text-white shadow-lg shadow-amber-500/30 transition-transform duration-300 group-hover:scale-105">
            <i class="fas fa-ticket"></i>
          </div>
          <div class="min-w-0 flex-1 pt-0.5">
            <div class="flex items-start justify-between gap-2">
              <h2 class="font-display text-xl font-bold text-stone-900">Bilety</h2>
              <i class="fas fa-arrow-right text-sm text-stone-300 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-amber-600"></i>
            </div>
            <p class="mt-1 text-sm text-stone-500">Rezerwacje, miejsca i status płatności.</p>
            <span class="mt-4 inline-flex rounded-full bg-amber-50 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-amber-900 ring-1 ring-amber-100">Sprzedaż</span>
          </div>
        </div>
      </div>

      <div
        id="openHallsManager"
        class="group relative cursor-pointer overflow-hidden rounded-3xl border border-stone-200/90 bg-white/95 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/50 transition-all duration-300 hover:-translate-y-1 hover:border-emerald-200 hover:shadow-xl hover:shadow-emerald-200/20 active:scale-[0.99] md:p-7"
      >
        <div class="absolute right-0 top-0 h-24 w-24 translate-x-6 -translate-y-6 rounded-full bg-emerald-400/15 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative flex items-start gap-5">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 text-xl text-white shadow-lg shadow-emerald-500/30 transition-transform duration-300 group-hover:scale-105">
            <i class="fas fa-couch"></i>
          </div>
          <div class="min-w-0 flex-1 pt-0.5">
            <div class="flex items-start justify-between gap-2">
              <h2 class="font-display text-xl font-bold text-stone-900">Sale</h2>
              <i class="fas fa-arrow-right text-sm text-stone-300 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-emerald-600"></i>
            </div>
            <p class="mt-1 text-sm text-stone-500">Układ miejsc i pojemność sal.</p>
            <span class="mt-4 inline-flex rounded-full bg-emerald-50 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-emerald-900 ring-1 ring-emerald-100">Układ sal</span>
          </div>
        </div>
      </div>

      <div
        id="openUsersManager"
        class="group relative cursor-pointer overflow-hidden rounded-3xl border border-stone-200/90 bg-white/95 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/50 transition-all duration-300 hover:-translate-y-1 hover:border-sky-200 hover:shadow-xl hover:shadow-sky-200/20 active:scale-[0.99] md:p-7"
      >
        <div class="absolute right-0 top-0 h-24 w-24 translate-x-6 -translate-y-6 rounded-full bg-sky-400/15 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative flex items-start gap-5">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-sky-500 to-blue-600 text-xl text-white shadow-lg shadow-sky-500/30 transition-transform duration-300 group-hover:scale-105">
            <i class="fas fa-users"></i>
          </div>
          <div class="min-w-0 flex-1 pt-0.5">
            <div class="flex items-start justify-between gap-2">
              <h2 class="font-display text-xl font-bold text-stone-900">Użytkownicy</h2>
              <i class="fas fa-arrow-right text-sm text-stone-300 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-sky-600"></i>
            </div>
            <p class="mt-1 text-sm text-stone-500">Konta, role i uprawnienia.</p>
            <span class="mt-4 inline-flex rounded-full bg-sky-50 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-sky-900 ring-1 ring-sky-100">Klienci i zespół</span>
          </div>
        </div>
      </div>

      <div
        id="openStatsManager"
        class="group relative cursor-pointer overflow-hidden rounded-3xl border border-stone-200/90 bg-white/95 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/50 transition-all duration-300 hover:-translate-y-1 hover:border-stone-300 hover:shadow-xl hover:shadow-stone-400/15 active:scale-[0.99] md:p-7"
      >
        <div class="absolute right-0 top-0 h-24 w-24 translate-x-6 -translate-y-6 rounded-full bg-stone-400/10 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative flex items-start gap-5">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-stone-700 to-stone-900 text-xl text-white shadow-lg shadow-stone-900/25 transition-transform duration-300 group-hover:scale-105">
            <i class="fas fa-chart-line"></i>
          </div>
          <div class="min-w-0 flex-1 pt-0.5">
            <div class="flex items-start justify-between gap-2">
              <h2 class="font-display text-xl font-bold text-stone-900">Statystyki</h2>
              <i class="fas fa-arrow-right text-sm text-stone-300 transition-all duration-300 group-hover:translate-x-0.5 group-hover:text-stone-700"></i>
            </div>
            <p class="mt-1 text-sm text-stone-500">Podsumowania i dane operacyjne.</p>
            <span class="mt-4 inline-flex rounded-full bg-stone-100 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-stone-700 ring-1 ring-stone-200">Analityka</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="moviesManagerOverlay" class="fixed inset-x-0 top-[var(--layout-modal-top)] bottom-[var(--layout-modal-bottom)] z-[2000] hidden min-h-0 min-w-0 items-stretch justify-center overflow-hidden overscroll-contain bg-stone-900/65 p-2 sm:p-3 md:p-4 animate-fade-in">
  <div class="manager-container mx-auto flex h-full max-h-full min-h-0 min-w-0 w-full max-w-full flex-1 flex-col overflow-hidden rounded-xl border border-stone-200 bg-white shadow-2xl shadow-stone-400/30 sm:rounded-2xl md:max-w-5xl md:rounded-[2rem]" id="movieManagerContainer">
    <header class="flex shrink-0 flex-col gap-3 border-b border-stone-200 bg-stone-50 px-3 py-2 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-4 sm:py-3 md:px-6 md:py-4">
      <h2 id="managerTitle" class="min-w-0 break-words text-lg font-display font-black tracking-tight text-stone-900 sm:text-xl md:text-2xl">Zarządzanie Filmami</h2>
      <div class="flex w-full min-w-0 flex-wrap items-center justify-end gap-2 sm:w-auto sm:flex-nowrap sm:gap-3">
        <button type="button" id="backToTableBtn" class="hidden inline-flex shrink-0 items-center gap-2 rounded-xl border border-stone-200 bg-white px-3 py-2.5 text-sm font-bold text-stone-700 transition-all hover:bg-stone-100 sm:gap-3 sm:px-5 sm:py-2.5 sm:text-base">
          <i class="fas fa-arrow-left"></i> Powrót
        </button>
        <button type="button" id="addMovieBtn" class="btn-primary inline-flex shrink-0 px-3 py-2.5 text-sm font-black italic sm:px-6 sm:py-3 sm:text-base">
          <i class="fas fa-plus mr-1.5 sm:mr-2"></i>Dodaj Film
        </button>
        <button type="button" id="closeManagerBtn" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-slate-500 transition-colors hover:bg-stone-100 hover:text-stone-900 sm:h-11 sm:w-11">
          <i class="fas fa-times text-xl sm:text-2xl"></i>
        </button>
      </div>
    </header>
    
    <div class="admin-slide-wrap flex min-h-0 min-w-0 w-[200%] flex-1 transition-transform duration-500 cubic-bezier(0.4, 0, 0.2, 1)" id="viewsWrapper">
      <div class="min-h-0 min-w-0 max-h-full w-1/2 touch-pan-x touch-pan-y overflow-x-auto overflow-y-auto overscroll-x-contain p-2 sm:p-3 md:p-5" id="moviesListContent">
        <div class="min-w-0 max-w-full overflow-x-auto rounded-3xl border border-stone-200 bg-stone-50/80">
          <table class="admin-table w-full text-left text-base">
            <thead class="bg-stone-100 text-xs font-black uppercase tracking-widest text-slate-600">
              <tr>
                <th class="p-6">ID</th>
                <th class="p-6">Plakat</th>
                <th class="p-6">Tytuł i czas</th>
                <th class="p-6">Emisja</th>
                <th class="p-6 text-right">Akcje</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-stone-200">
              {{#each movies}}
              <tr class="group transition-colors hover:bg-rose-50/60">
                <td class="p-6 font-mono text-slate-600">#{{this.id}}</td>
                <td class="p-6">
                  <div class="relative h-16 w-12 shrink-0 overflow-hidden rounded-lg bg-slate-800 shadow-lg ring-1 ring-white/10">
                    {{#if this.image_url}}<img src="{{this.image_url}}" class="h-full w-full object-cover">
                    {{else}}<div class="flex h-full w-full items-center justify-center text-slate-600 italic text-[10px]">BRAK</div>{{/if}}
                  </div>
                </td>
                <td class="p-6">
                  <div class="font-bold text-stone-900 text-base leading-tight">{{this.title}}</div>
                  <div class="mt-1 text-sm font-bold text-rose-600">{{this.duration}} min</div>
                </td>
                <td class="p-6 text-slate-400 font-medium">
                   <div class="text-xs text-slate-500 font-bold uppercase tracking-tight">OD: {{formatDateInput this.release_date}}</div>
                   <div class="text-xs text-slate-500 font-bold uppercase tracking-tight">DO: {{formatDateInput this.end_date}}</div>
                </td>
                <td class="p-6 text-right">
                  <div class="flex justify-end gap-2">
                    <button type="button" class="edit-movie-btn flex h-10 w-10 items-center justify-center rounded-xl bg-amber-500/10 text-amber-500 hover:bg-amber-500 hover:text-white transition-all active:scale-90"
                      data-id="{{this.id}}" data-title="{{this.title}}" data-description="{{this.description}}"
                      data-duration="{{this.duration}}" data-release-date="{{this.release_date}}"
                      data-end-date="{{this.end_date}}" data-image-url="{{this.image_url}}"
                      data-youtube-link="{{this.youtube_link}}"><i class="fas fa-edit"></i></button>
                    <form action="/admin/movies/delete" method="POST" class="inline" onsubmit="return confirm('Trwale usunąć ten film?');">
                      <input type="hidden" name="id" value="{{this.id}}">
                      <button type="submit" class="flex h-10 w-10 items-center justify-center rounded-xl bg-rose-500/10 text-rose-500 hover:bg-rose-500 hover:text-white transition-all active:scale-90"><i class="fas fa-trash"></i></button>
                    </form>
                  </div>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
          <div id="adminPaginationMovies" class="border-t border-stone-200 bg-stone-100/70 px-4 py-3 md:px-5"></div>
        </div>
      </div>

      <div class="min-h-0 min-w-0 max-h-full w-1/2 touch-pan-x touch-pan-y overflow-x-auto overflow-y-auto overscroll-x-contain border-l border-stone-200 p-2 sm:p-3 md:p-5" id="movieFormContent">
        <form id="movieForm" action="/admin/movies/add" method="POST" class="space-y-4">
          <input type="hidden" name="id" id="movieId">
          <div class="grid gap-4 md:grid-cols-2">
            <div class="md:col-span-2 space-y-3">
              <label class="text-xs font-bold uppercase tracking-widest text-slate-600 pl-1">Tytuł Filmu</label>
              <input type="text" name="title" id="inputTitle" required placeholder="np. Diuna: Część Druga" class="w-full rounded-2xl border border-stone-200 bg-white px-6 py-4 text-base text-stone-900 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100 transition-all">
            </div>
            <div class="space-y-3">
              <label class="text-xs font-bold uppercase tracking-widest text-slate-600 pl-1">Data Premiery</label>
              <input type="date" name="release_date" id="inputReleaseDate" required class="w-full rounded-2xl border border-stone-200 bg-white px-6 py-4 text-base text-stone-900 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100 transition-all">
            </div>
            <div class="space-y-3">
              <label class="text-xs font-bold uppercase tracking-widest text-slate-600 pl-1">Koniec Emisji</label>
              <input type="date" name="end_date" id="inputEndDate" class="w-full rounded-2xl border border-stone-200 bg-white px-6 py-4 text-base text-stone-900 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100 transition-all">
            </div>
            <div class="space-y-3">
              <label class="text-xs font-bold uppercase tracking-widest text-slate-600 pl-1">Czas (minuty)</label>
              <input type="number" name="duration" id="inputDuration" placeholder="120" class="w-full rounded-2xl border border-stone-200 bg-white px-6 py-4 text-base text-stone-900 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100 transition-all">
            </div>
            <div class="space-y-3">
              <label class="text-xs font-bold uppercase tracking-widest text-slate-600 pl-1">Plakat (URL)</label>
              <input type="text" name="image_url" id="inputImageUrl" placeholder="https://..." class="w-full rounded-2xl border border-stone-200 bg-white px-6 py-4 text-base text-stone-900 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100 transition-all">
            </div>
            <div class="md:col-span-2 space-y-3">
              <label class="text-xs font-bold uppercase tracking-widest text-slate-600 pl-1">YouTube Trailer (URL)</label>
              <input type="text" name="youtube_link" id="inputYoutube" placeholder="https://youtube.com/..." class="w-full rounded-2xl border border-stone-200 bg-white px-6 py-4 text-base text-stone-900 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100 transition-all">
            </div>
            <div class="md:col-span-2 space-y-3">
              <label class="text-xs font-bold uppercase tracking-widest text-slate-600 pl-1">Streszczenie fabuły</label>
              <textarea name="description" id="inputDescription" rows="5" class="w-full rounded-[2rem] border border-stone-200 bg-white px-6 py-4 text-base text-stone-900 outline-none focus:border-rose-400 focus:ring-2 focus:ring-rose-100 transition-all"></textarea>
            </div>
          </div>
          <div class="pt-6 border-t border-stone-200 flex justify-end">
            <button type="submit" class="btn-primary px-8 py-3 font-black text-lg italic md:px-10 md:py-4 md:text-xl">Zapisz Film</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>

<div id="usersManagerOverlay" class="fixed inset-x-0 top-[var(--layout-modal-top)] bottom-[var(--layout-modal-bottom)] z-[2000] hidden min-h-0 min-w-0 items-stretch justify-center overflow-hidden overscroll-contain bg-stone-900/65 p-2 sm:p-3 md:p-4 animate-fade-in">
  <div class="manager-container mx-auto flex h-full max-h-full min-h-0 min-w-0 w-full max-w-full flex-1 flex-col overflow-hidden rounded-xl border border-stone-200 bg-white shadow-2xl shadow-stone-400/30 sm:rounded-2xl md:max-w-5xl md:rounded-[2rem]" id="userManagerContainer">
    <header class="flex shrink-0 flex-col gap-3 border-b border-stone-200 bg-stone-50 px-3 py-2 sm:flex-row sm:items-center sm:justify-between sm:gap-4 sm:px-4 sm:py-3 md:px-6 md:py-4">
      <h2 id="user-managerTitle" class="min-w-0 break-words text-lg font-display font-black tracking-tight text-stone-900 sm:text-xl md:text-2xl">Baza Użytkowników</h2>
      <div class="flex w-full min-w-0 flex-wrap items-center justify-end gap-2 sm:w-auto sm:flex-nowrap sm:gap-3">
        <button type="button" id="backToUserListBtn" class="hidden inline-flex shrink-0 items-center rounded-xl border border-stone-200 bg-white px-3 py-2.5 text-sm font-bold text-stone-700 transition-colors hover:bg-stone-100 sm:px-5 sm:py-2.5 sm:text-base">Powrót</button>
        <button type="button" id="addUserBtn" class="btn-primary inline-flex shrink-0 px-3 py-2.5 text-sm font-black italic sm:px-6 sm:py-3 sm:text-base">Dodaj Użytkownika</button>
        <button type="button" id="closeUserManagerBtn" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full text-slate-500 transition-colors hover:bg-stone-100 hover:text-stone-900 sm:h-11 sm:w-11"><i class="fas fa-times text-xl sm:text-2xl"></i></button>
      </div>
    </header>
    <div class="admin-slide-wrap flex min-h-0 min-w-0 w-[200%] flex-1 transition-transform duration-500 cubic-bezier(0.4, 0, 0.2, 1)" id="user-viewsWrapper">
      <div class="min-h-0 min-w-0 max-h-full w-1/2 touch-pan-x touch-pan-y space-y-4 overflow-x-auto overflow-y-auto overscroll-x-contain p-2 sm:p-3 md:p-5" id="usersListContent">
        <div class="flex flex-col gap-3 rounded-3xl border border-stone-200 bg-stone-50 p-3 shadow-inner sm:flex-row sm:flex-wrap sm:items-center sm:gap-4 sm:p-4">
          <select id="filterUserRole" class="min-w-0 flex-1 rounded-xl border border-stone-200 bg-white px-4 py-3 text-sm font-bold text-stone-900 outline-none focus:border-rose-400 sm:min-w-[12rem] sm:flex-none sm:px-5">
            <option value="all">Wszyscy użytkownicy</option>
            <option value="user">Tylko Klienci</option>
            <option value="employee">Pracownicy</option>
            <option value="admin">Administratorzy</option>
          </select>
          <button type="button" id="resetUserFiltersBtn" class="shrink-0 self-start text-xs font-bold uppercase tracking-widest text-slate-500 transition-colors hover:text-rose-500 sm:self-center sm:pl-2">Zresetuj widok</button>
        </div>
        <div class="min-w-0 max-w-full overflow-x-auto rounded-3xl border border-stone-200 bg-stone-50/80">
          <table class="admin-table w-full text-left text-base">
