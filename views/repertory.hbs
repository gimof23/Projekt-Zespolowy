<div class="relative flex-1 px-4 pb-12 pt-10 md:px-8 md:pb-16">
  <div class="relative z-10 mx-auto w-full max-w-6xl">
    <header class="mb-8 text-center animate-slide-up md:mb-10">
      <h1 class="text-3xl font-extrabold tracking-tight text-stone-900 sm:text-5xl">Repertuar kinowy</h1>
      <p class="mt-4 text-stone-600">Wybierz datę i zarezerwuj bilet w kilka sekund</p>
    </header>

    <div class="mb-8 w-full md:mb-10">
      <div class="w-full rounded-[1.75rem] border border-stone-200/90 bg-gradient-to-br from-white via-stone-50/80 to-rose-50/40 p-2 shadow-lg shadow-stone-900/10 ring-1 ring-stone-900/5 md:rounded-[2rem] md:p-2.5">
        <div class="grid w-full grid-cols-7 gap-1 md:gap-2" id="datesContainer">
        </div>
      </div>
    </div>

    <div id="moviesContainer" class="min-h-96 space-y-8 animate-fade-in" style="animation-delay: 0.2s">
      <div class="flex min-h-96 flex-col items-center justify-center gap-6 rounded-3xl border border-dashed border-stone-300 bg-white/60 text-stone-500">
        <div class="relative h-12 w-12 text-rose-500">
          <i class="fas fa-circle-notch fa-spin text-4xl"></i>
          <div class="absolute inset-0 animate-pulse bg-rose-500/20 blur-lg"></div>
        </div>
        <p class="font-medium tracking-wide">Przygotowujemy listę seansów…</p>
      </div>
    </div>
  </div>
</div>

<template id="date-card-template">
  <button type="button" class="date-card group relative flex min-h-[4.25rem] w-full min-w-0 flex-col items-center justify-center rounded-xl border border-stone-200/90 bg-white/95 px-1 py-3 shadow-sm transition-all duration-200 active:scale-[0.98] sm:px-2 sm:py-3.5 md:min-h-[4.75rem] md:rounded-2xl md:px-3 md:py-4">
    <span class="day-name max-w-full truncate text-[9px] font-bold uppercase tracking-wide text-stone-500 sm:text-[10px] sm:tracking-[0.14em] md:text-[11px]"></span>
    <span class="day-date mt-1 text-base font-black tabular-nums tracking-tight text-stone-900 sm:mt-1.5 sm:text-lg md:text-xl"></span>
  </button>
</template>

<template id="movie-card-template">
  <article class="movie-card glass-card group overflow-hidden rounded-3xl p-2 shadow-md transition-all hover:shadow-lg hover:shadow-rose-100/40 md:flex">
    <div class="movie-poster relative aspect-[2/3] w-full shrink-0 overflow-hidden rounded-2xl md:w-64">
      <img src="" alt="" class="poster-img h-full w-full object-cover transition-transform duration-500 group-hover:scale-105">
      <div class="no-poster absolute inset-0 hidden flex-col items-center justify-center gap-3 bg-stone-200 text-stone-500">
        <i class="fas fa-film text-4xl"></i>
        <span class="text-xs font-bold uppercase tracking-widest">Brak plakatu</span>
      </div>
      <div class="absolute right-3 top-3 rounded-lg border border-white/30 bg-black/55 px-2 py-1 text-[10px] font-bold text-white">
        4K / ATMOS
      </div>
    </div>

    <div class="movie-info flex flex-1 flex-col p-6 md:px-10 md:py-8">
      <div class="flex flex-wrap items-start justify-between gap-4">
        <div class="space-y-2">
          <h2 class="movie-title text-2xl font-black text-stone-900 md:text-4xl"></h2>
          <div class="flex items-center gap-3">
             <span class="movie-genre rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-[10px] font-bold uppercase tracking-wider text-rose-700"></span>
             <span class="movie-duration text-sm font-medium text-stone-500"></span>
          </div>
        </div>
      </div>

      <p class="movie-description mt-6 line-clamp-3 text-sm leading-relaxed text-stone-600 md:text-base"></p>

      <div class="showtimes-section mt-auto pt-8">
        <div class="mb-4 flex items-center gap-2">
           <div class="h-1 w-1 rounded-full bg-rose-500 shadow-lg shadow-rose-500"></div>
           <p class="text-[10px] font-bold uppercase tracking-widest text-stone-500">Dzisiejsze seanse</p>
        </div>
        <div class="showtimes-list flex flex-wrap gap-3"></div>
      </div>
    </div>
  </article>
</template>

<template id="time-btn-template">
  <a href="#" class="time-btn group/time relative flex min-w-[5rem] flex-col items-center rounded-xl border border-stone-200 bg-white px-4 py-3 shadow-sm transition-all hover:border-rose-400 hover:bg-rose-500">
    <span class="time text-lg font-black text-stone-800 transition-transform group-hover/time:scale-105 group-hover/time:text-white"></span>
    <span class="hall text-[9px] font-bold uppercase tracking-tighter text-stone-500 group-hover/time:text-white/90"></span>
  </a>
</template>

<template id="no-movies-template">
  <div class="flex flex-col items-center justify-center rounded-3xl border border-dashed border-stone-300 bg-white/70 py-24 text-center">
    <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-amber-100 text-amber-600">
      <i class="fas fa-calendar-times text-3xl"></i>
    </div>
    <h3 class="text-xl font-bold text-stone-900">Brak seansów tego dnia</h3>
    <p class="mt-2 text-stone-600">Spróbuj wybrać inną datę z kalendarza powyżej.</p>
  </div>
</template>

<style>
