<div class="relative flex-1 px-4 pb-24 pt-8 leading-relaxed md:px-8 md:pt-12">
  <div class="relative z-10 mx-auto max-w-6xl">
    <header class="mb-10 animate-slide-up md:mb-12">
      <div class="flex flex-col gap-6 lg:flex-row lg:items-end lg:justify-between">
        <div class="max-w-2xl">
          <p class="font-display text-[11px] font-bold uppercase tracking-[0.28em] text-amber-600/90 md:text-xs">CinemaŚty — obsługa kina</p>
          <h1 class="mt-3 font-display text-4xl font-black leading-[1.08] tracking-tight text-stone-900 md:text-5xl">
            <span class="bg-gradient-to-r from-stone-900 via-amber-800 to-rose-800 bg-clip-text text-transparent">Panel</span>
            <span class="text-stone-800"> pracownika</span>
          </h1>
          <p class="mt-4 text-base leading-relaxed text-stone-600 md:text-lg">Sprzedaż, seanse i bilety w jednym miejscu.</p>
          <div class="mt-5 inline-flex items-center gap-3 rounded-2xl border border-stone-200/90 bg-white/90 px-4 py-2.5 shadow-md shadow-stone-900/5 ring-1 ring-stone-200/60">
            <span class="text-xs font-bold uppercase tracking-widest text-stone-400">Zalogowany</span>
            <span class="font-display text-sm font-bold text-stone-900">{{user.name}}</span>
          </div>
        </div>
        <div class="hidden shrink-0 rounded-3xl border border-stone-200/90 bg-white/90 px-6 py-5 text-right shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/60 sm:block">
          <p class="text-xs font-bold uppercase tracking-widest text-stone-400">Dziś</p>
          <p class="mt-1 font-display text-base font-bold text-stone-800">Statystyki i skróty poniżej</p>
        </div>
      </div>
    </header>

    <div class="mb-10 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4 lg:gap-6 animate-fade-in" style="animation-delay: 0.06s">
      <div class="group relative overflow-hidden rounded-3xl border border-stone-200/90 bg-white/95 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/50 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl md:p-7">
        <div class="absolute right-0 top-0 h-20 w-20 translate-x-4 -translate-y-4 rounded-full bg-rose-400/15 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-rose-500 to-rose-600 text-lg text-white shadow-lg shadow-rose-500/30">
            <i class="fas fa-ticket-alt"></i>
          </div>
          <p class="text-xs font-bold uppercase tracking-widest text-stone-500">Sprzedano dzisiaj</p>
          <p class="mt-2 font-display text-3xl font-black tracking-tight text-stone-900 md:text-4xl">{{stats.tickets_sold}}</p>
        </div>
      </div>

      <div class="group relative overflow-hidden rounded-3xl border border-stone-200/90 bg-white/95 p-6 shadow-lg shadow-stone-900/5 ring-1 ring-stone-200/50 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl md:p-7">
        <div class="absolute right-0 top-0 h-20 w-20 translate-x-4 -translate-y-4 rounded-full bg-emerald-400/15 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative">
          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-emerald-500 to-teal-600 text-lg text-white shadow-lg shadow-emerald-500/30">
            <i class="fas fa-coins"></i>
          </div>
          <p class="text-xs font-bold uppercase tracking-widest text-stone-500">Utarg dzisiaj</p>
          <p class="mt-2 font-display text-3xl font-black tracking-tight text-emerald-700 md:text-4xl">{{stats.revenue}} <span class="text-lg font-bold text-emerald-600/80">PLN</span></p>
        </div>
      </div>

      <button type="button" onclick="openScreeningManager()" class="group relative cursor-pointer overflow-hidden rounded-3xl border-2 border-amber-300/90 bg-white/95 p-6 text-left shadow-lg shadow-stone-900/5 ring-1 ring-amber-200/50 transition-all duration-300 hover:-translate-y-1 hover:border-amber-400 hover:shadow-xl hover:shadow-amber-200/20 active:scale-[0.99] md:p-7">
        <div class="absolute right-0 top-0 h-20 w-20 translate-x-4 -translate-y-4 rounded-full bg-amber-400/20 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-500 to-orange-600 text-lg text-white shadow-lg shadow-amber-500/30">
            <i class="fas fa-calendar-days"></i>
          </div>
          <div class="min-w-0">
            <p class="text-xs font-bold uppercase tracking-widest text-amber-800/80">Seanse</p>
            <p class="mt-1 font-display text-lg font-bold text-stone-900">Planuj i edytuj</p>
            <span class="mt-3 inline-flex items-center gap-1 text-xs font-bold text-amber-700">Otwórz <i class="fas fa-arrow-right text-[10px] transition-transform group-hover:translate-x-0.5"></i></span>
          </div>
        </div>
      </button>

      <button type="button" onclick="openTicketManager()" class="group relative cursor-pointer overflow-hidden rounded-3xl border-2 border-sky-300/90 bg-white/95 p-6 text-left shadow-lg shadow-stone-900/5 ring-1 ring-sky-200/50 transition-all duration-300 hover:-translate-y-1 hover:border-sky-400 hover:shadow-xl hover:shadow-sky-200/20 active:scale-[0.99] md:p-7">
        <div class="absolute right-0 top-0 h-20 w-20 translate-x-4 -translate-y-4 rounded-full bg-sky-400/15 transition-transform duration-500 group-hover:scale-150"></div>
        <div class="relative flex items-start gap-4">
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-sky-500 to-blue-600 text-lg text-white shadow-lg shadow-sky-500/30">
            <i class="fas fa-clipboard-list"></i>
          </div>
          <div class="min-w-0">
            <p class="text-xs font-bold uppercase tracking-widest text-sky-800/80">Bilety</p>
            <p class="mt-1 font-display text-lg font-bold text-stone-900">Wyszukaj i zwroty</p>
            <span class="mt-3 inline-flex items-center gap-1 text-xs font-bold text-sky-700">Otwórz <i class="fas fa-arrow-right text-[10px] transition-transform group-hover:translate-x-0.5"></i></span>
          </div>
        </div>
      </button>
    </div>

    <div class="overflow-hidden rounded-[2rem] border border-stone-200/90 bg-white/95 shadow-xl shadow-stone-900/5 ring-1 ring-stone-200/50 animate-fade-in" style="animation-delay: 0.12s">
      <div class="flex flex-col gap-1 border-b border-stone-200 bg-gradient-to-r from-stone-50 to-white px-6 py-5 md:flex-row md:items-center md:justify-between md:px-8">
        <div>
          <h2 class="font-display text-xl font-black text-stone-900 md:text-2xl">Sprzedaż na nadchodzące seanse</h2>
          <p class="mt-1 text-sm text-stone-500 md:text-base">Zajętość miejsc i szybki link do kasy.</p>
        </div>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-[900px] w-full border-collapse text-left text-sm md:text-base">
          <thead>
            <tr class="border-b border-stone-200 bg-stone-100 text-sm font-black uppercase tracking-wide text-slate-600 md:text-base">
              <th class="p-4 md:p-5">Data</th>
              <th class="p-4 md:p-5">Godzina</th>
              <th class="p-4 md:p-5">Film</th>
              <th class="p-4 md:p-5">Sala</th>
              <th class="p-4 md:p-5">Zajęte</th>
              <th class="p-4 md:p-5">Status</th>
              <th class="p-4 md:p-5 text-right">Akcja</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-stone-200">
            {{#each screenings}}
            <tr class="transition-colors hover:bg-rose-50/40">
              <td class="p-4 font-semibold text-stone-700 md:p-5">{{this.displayDate}}</td>
              <td class="p-4 md:p-5"><span class="font-display text-lg font-black text-stone-900">{{this.time}}</span></td>
              <td class="p-4 font-bold text-stone-900 md:p-5">{{this.movie_title}}</td>
              <td class="p-4 text-stone-600 md:p-5">{{this.hall_name}}</td>
              <td class="p-4 md:p-5">
                <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:gap-3">
                  <span class="text-xs font-bold text-stone-600">{{this.sold_count}}/{{this.total_seats}}</span>
                  <div class="h-2.5 w-full max-w-[7rem] overflow-hidden rounded-full bg-stone-200">
                    <div class="h-full rounded-full transition-all {{#if (gt this.occupancy 90)}}bg-rose-500{{else}}bg-emerald-500{{/if}}" style="width: {{this.occupancy}}%;"></div>
                  </div>
                </div>
              </td>
              <td class="p-4 md:p-5">
                {{#if this.cancelled}}
                <span class="inline-flex rounded-full bg-rose-100 px-3 py-1 text-xs font-black uppercase tracking-wide text-rose-800 ring-1 ring-rose-200">Odwołany</span>
                {{else}}
                <span class="inline-flex rounded-full bg-emerald-100 px-3 py-1 text-xs font-black uppercase tracking-wide text-emerald-800 ring-1 ring-emerald-200">Aktywny</span>
                {{/if}}
              </td>
              <td class="p-4 text-right md:p-5">
                {{#unless this.cancelled}}
                <a href="/rezerwacja/{{this.id}}" class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-sky-600 to-blue-600 px-4 py-2.5 text-xs font-black uppercase tracking-wide text-white shadow-md shadow-sky-500/25 transition hover:from-sky-500 hover:to-blue-500 active:scale-[0.98]">
                  Sprzedaj
                </a>
                {{/unless}}
              </td>
            </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<div id="screeningsManagerOverlay" class="fixed inset-x-0 top-[var(--layout-modal-top)] bottom-[var(--layout-modal-bottom)] z-[2000] hidden w-full min-h-0 items-center justify-center overflow-x-hidden overflow-y-auto overscroll-contain bg-stone-900/65 px-4 py-3 sm:px-5 sm:py-4 animate-fade-in">
  <div class="mx-auto flex h-full max-h-full min-h-0 w-full max-w-4xl flex-shrink-0 flex-col overflow-hidden rounded-[2rem] border border-stone-200 bg-white text-[15px] shadow-2xl shadow-stone-400/30 sm:rounded-[2.5rem] md:text-base" id="managerContainer">
    <div class="flex shrink-0 flex-wrap items-center justify-between gap-2 border-b border-stone-200 bg-stone-50 px-4 py-3 md:px-5 md:py-4">
      <h2 class="font-display text-xl font-black tracking-tight text-stone-900 md:text-2xl">Zarządzanie seansami</h2>
      <div class="flex flex-wrap items-center gap-2 md:gap-3">
        <button type="button" id="backToTableBtn" class="inline-flex items-center gap-2 rounded-xl border border-stone-200 bg-white px-4 py-2.5 text-base font-bold text-stone-700 transition hover:bg-stone-100">
          <i class="fas fa-arrow-left"></i> Wróć
        </button>
        <button type="button" id="addScreeningBtn" class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-r from-emerald-600 to-teal-600 px-4 py-2.5 text-base font-black text-white shadow-md shadow-emerald-500/25 transition hover:from-emerald-500 hover:to-teal-500">
          <i class="fas fa-plus"></i> Dodaj seans
        </button>
        <button type="button" id="closeManagerBtn" class="flex h-10 w-10 items-center justify-center rounded-full text-stone-500 transition hover:bg-stone-200 hover:text-rose-600">
          <span class="text-2xl leading-none">&times;</span>
        </button>
      </div>
    </div>

    <div class="relative min-h-0 flex-1 overflow-hidden">
      <div id="empScreeningSlide" class="flex h-full min-h-[18rem] w-[200%] transition-transform duration-500 ease-out">
        <div class="w-1/2 shrink-0 overflow-y-auto p-3 md:p-4" id="screeningsListContent">
          <div class="overflow-hidden rounded-2xl border border-stone-200 bg-stone-50/80">
            <table class="w-full border-collapse text-base">
              <thead>
                <tr class="border-b border-stone-200 bg-stone-100 text-xs font-black uppercase tracking-widest text-slate-600">
                  <th class="p-3 text-left md:p-4">ID</th>
                  <th class="p-3 text-left md:p-4">Film</th>
                  <th class="p-3 text-left md:p-4">Sala</th>
                  <th class="p-3 text-left md:p-4">Data</th>
                  <th class="p-3 text-left md:p-4">Godz.</th>
                  <th class="p-3 text-left md:p-4">Status</th>
                  <th class="p-3 text-right md:p-4">Edycja</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-stone-200">
                {{#each screenings}}
                <tr class="{{#if this.cancelled}}bg-rose-50/60{{else if this.isFinished}}bg-stone-100/80 opacity-70{{else}}hover:bg-rose-50/30{{/if}} transition-colors">
                  <td class="p-3 font-mono text-sm text-stone-500 md:p-4">#{{this.id}}</td>
                  <td class="p-3 text-base font-bold text-stone-900 md:p-4">{{this.movie_title}}</td>
                  <td class="p-3 text-base text-stone-600 md:p-4">{{this.hall_name}}</td>
                  <td class="p-3 text-base text-stone-600 md:p-4">{{this.displayDate}}</td>
                  <td class="p-3 text-base font-bold text-stone-900 md:p-4">{{this.time}}</td>
                  <td class="p-3 md:p-4">
                    {{#if this.cancelled}}
                    <span class="inline-flex rounded-full bg-rose-100 px-2.5 py-1 text-xs font-black uppercase text-rose-800">Odwołany</span>
                    {{else if this.isFinished}}
                    <span class="inline-flex rounded-full bg-stone-200 px-2.5 py-1 text-xs font-black uppercase text-stone-700">Zakończony</span>
                    {{else}}
                    <span class="inline-flex rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-black uppercase text-emerald-800">Aktywny</span>
                    {{/if}}
                  </td>
                  <td class="p-3 text-right md:p-4">
                    <div class="flex justify-end gap-2">
                      {{#unless this.isFinished}}
                      <button type="button" class="edit-screening-btn flex h-10 w-10 items-center justify-center rounded-xl bg-amber-500/15 text-amber-600 transition hover:bg-amber-500 hover:text-white" data-id="{{this.id}}" data-movie-id="{{this.movie_id}}" data-hall-id="{{this.hall_id}}" data-date="{{formatDateInput this.date}}" data-time="{{this.time}}" data-cancelled="{{this.cancelled}}">
                        <i class="fas fa-edit text-base"></i>
                      </button>
                      <form action="/employee/screenings/delete" method="POST" class="inline" onsubmit="return confirm('Na pewno usunąć ten seans?');">
                        <input type="hidden" name="id" value="{{this.id}}">
                        <button type="submit" class="flex h-10 w-10 items-center justify-center rounded-xl bg-rose-500/15 text-rose-600 transition hover:bg-rose-600 hover:text-white">
                          <i class="fas fa-trash text-base"></i>
                        </button>
                      </form>
                      {{else}}
                      <span class="text-sm text-stone-400">—</span>
                      {{/unless}}
                    </div>
                  </td>
                </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        </div>
        <div class="w-1/2 shrink-0 overflow-y-auto border-l border-stone-200 bg-white p-3 md:p-5" id="screeningFormContent">
          <div class="mx-auto max-w-md">
            <h3 id="formTitle" class="mb-4 font-display text-xl font-black text-stone-900 md:text-2xl">Dodaj seans</h3>
            <form id="screeningForm" action="/employee/screenings/add" method="POST" class="flex flex-col gap-4">
              <input type="hidden" name="id" id="screeningId">
              <div class="flex flex-col gap-2">
                <label class="text-sm font-bold uppercase tracking-widest text-slate-600">Film</label>
                <select name="movie_id" id="inputScreeningMovie" required class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3.5 text-base text-stone-900 outline-none transition focus:border-rose-400 focus:ring-2 focus:ring-rose-100">
                  {{#each activeMovies}}<option value="{{this.id}}">{{this.title}}</option>{{/each}}
                </select>
              </div>
              <div class="flex flex-col gap-2">
                <label class="text-sm font-bold uppercase tracking-widest text-slate-600">Sala</label>
                <select name="hall_id" id="inputScreeningHall" required class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3.5 text-base text-stone-900 outline-none transition focus:border-rose-400 focus:ring-2 focus:ring-rose-100">
                  {{#each halls}}<option value="{{this.id}}">{{this.name}} ({{this.seats}} miejsc)</option>{{/each}}
                </select>
              </div>
              <div class="flex flex-col gap-2">
                <label class="text-sm font-bold uppercase tracking-widest text-slate-600">Data i godzina</label>
                <input type="datetime-local" name="date_time" id="inputScreeningDate" required class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3.5 text-base text-stone-900 outline-none transition focus:border-rose-400 focus:ring-2 focus:ring-rose-100">
              </div>
              <div class="hidden rounded-2xl border border-rose-200 bg-rose-50/50 p-4" id="cancelledGroup">
                <label class="flex cursor-pointer items-center gap-3">
                  <input type="checkbox" name="cancelled" id="inputScreeningCancelled" class="h-5 w-5 rounded border-stone-300 text-rose-600 focus:ring-rose-500">
                  <span class="text-base font-black uppercase tracking-wide text-rose-700">Seans odwołany</span>
                </label>
              </div>
              <div class="border-t border-stone-200 pt-4">
                <button type="submit" class="btn-primary w-full py-3 text-base font-black md:py-3.5 md:text-lg">Zapisz zmiany</button>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="ticketManagerModal" class="fixed inset-x-0 top-[var(--layout-modal-top)] bottom-[var(--layout-modal-bottom)] z-[2000] hidden w-full min-h-0 items-center justify-center overflow-x-hidden overflow-y-auto overscroll-contain bg-stone-900/65 px-4 py-3 sm:px-5 sm:py-4 animate-fade-in">
  <div class="mx-auto flex h-full max-h-full min-h-0 w-full max-w-4xl flex-shrink-0 flex-col overflow-hidden rounded-[2rem] border border-stone-200 bg-white text-[15px] shadow-2xl shadow-stone-400/30 sm:rounded-[2.5rem] md:text-base" id="ticketManagerContainer">
    <div class="flex shrink-0 items-center justify-between border-b border-stone-200 bg-stone-50 px-4 py-3 md:px-5 md:py-4">
      <h2 class="font-display text-xl font-black tracking-tight text-stone-900 md:text-2xl">Zarządzanie biletami</h2>
      <button type="button" class="flex h-10 w-10 items-center justify-center rounded-full text-stone-500 transition hover:bg-stone-200 hover:text-rose-600" onclick="closeTicketManager()">
        <span class="text-2xl leading-none">&times;</span>
      </button>
    </div>
    <div class="flex min-h-0 flex-1 flex-col gap-3 overflow-hidden p-3 md:p-4">
      <div class="flex flex-wrap items-end gap-2 rounded-2xl border border-stone-200 bg-stone-50/90 p-3 shadow-inner ring-1 ring-stone-200/60 md:gap-3 md:p-4">
        <div class="flex min-w-[180px] flex-1 flex-col gap-2">
          <label class="text-sm font-bold uppercase tracking-widest text-slate-600">Email</label>
          <input type="text" id="filterEmail" placeholder="np. kowalski@gmail.com" class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3.5 text-base text-stone-900 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-100">
        </div>
        <div class="flex min-w-[160px] flex-1 flex-col gap-2">
          <label class="text-sm font-bold uppercase tracking-widest text-slate-600">Film</label>
          <select id="filterMovie" class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3.5 text-base font-semibold text-stone-900 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-100">
            <option value="">Wszystkie filmy</option>
          </select>
        </div>
        <div class="flex min-w-[140px] flex-col gap-2">
          <label class="text-sm font-bold uppercase tracking-widest text-slate-600">Data seansu</label>
          <input type="date" id="filterDate" class="w-full rounded-2xl border border-stone-200 bg-white px-4 py-3.5 text-base text-stone-900 outline-none focus:border-sky-400 focus:ring-2 focus:ring-sky-100">
        </div>
        <button type="button" class="inline-flex items-center gap-2 rounded-2xl bg-gradient-to-r from-sky-600 to-blue-600 px-5 py-3.5 text-base font-black text-white shadow-md shadow-sky-500/25 transition hover:from-sky-500 hover:to-blue-500" onclick="searchTicketsResetPage()">
          <i class="fas fa-search"></i> Szukaj
        </button>
        <button type="button" class="rounded-2xl border border-amber-300 bg-amber-50 px-5 py-3.5 text-base font-black text-amber-900 transition hover:bg-amber-100" onclick="resetTicketFilters()">Resetuj</button>
      </div>
      <div class="flex min-h-0 flex-1 flex-col overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-inner shadow-stone-200/40">
        <div class="min-h-0 flex-1 overflow-auto">
          <table class="w-full min-w-[700px] border-collapse text-base">
            <thead>
              <tr class="sticky top-0 z-[1] border-b border-stone-200 bg-stone-100 text-xs font-black uppercase tracking-widest text-slate-600">
                <th class="p-3 text-left md:p-4">ID</th>
                <th class="p-3 text-left md:p-4">Klient</th>
                <th class="p-3 text-left md:p-4">Film</th>
                <th class="p-3 text-left md:p-4">Data seansu</th>
                <th class="p-3 text-left md:p-4">Miejsce</th>
                <th class="p-3 text-left md:p-4">Status</th>
                <th class="p-3 text-left md:p-4">Akcje</th>
              </tr>
            </thead>
            <tbody id="ticketsTableBody"></tbody>
          </table>
        </div>
        <div id="ticketsPaginationWrap" class="hidden shrink-0 border-t border-stone-200 bg-stone-50/95">
          <div class="flex flex-col gap-3 px-4 py-3 md:flex-row md:items-center md:justify-between md:px-5 md:py-4">
            <p id="ticketsPaginationInfo" class="text-sm font-semibold text-stone-600 md:text-base"></p>
            <div class="flex flex-wrap items-center gap-2">
              <button type="button" id="ticketsPrevPage" class="inline-flex items-center gap-2 rounded-xl border border-stone-300 bg-white px-4 py-2.5 text-sm font-black text-stone-800 transition hover:bg-stone-100 disabled:pointer-events-none disabled:opacity-35 md:text-base">
                <i class="fas fa-chevron-left text-xs"></i> Poprzednia
              </button>
              <button type="button" id="ticketsNextPage" class="inline-flex items-center gap-2 rounded-xl border border-stone-300 bg-white px-4 py-2.5 text-sm font-black text-stone-800 transition hover:bg-stone-100 disabled:pointer-events-none disabled:opacity-35 md:text-base">
                Następna <i class="fas fa-chevron-right text-xs"></i>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
    const overlay = document.getElementById('screeningsManagerOverlay');
    const slide = document.getElementById('empScreeningSlide');
    const form = document.getElementById('screeningForm');
    const formTitle = document.getElementById('formTitle');

    function openScreeningManager() {
        overlay.classList.remove('hidden');
        overlay.classList.add('flex');
    }

    document.getElementById('closeManagerBtn').addEventListener('click', () => {
        overlay.classList.add('hidden');
        overlay.classList.remove('flex');
        slide.classList.remove('-translate-x-1/2');
    });

    document.getElementById('addScreeningBtn').addEventListener('click', () => {
        form.reset();
        document.getElementById('cancelledGroup').classList.add('hidden');
        document.getElementById('screeningId').value = '';
        form.action = '/employee/screenings/add';
        formTitle.textContent = 'Dodaj nowy seans';
        slide.classList.add('-translate-x-1/2');
    });

    document.getElementById('backToTableBtn').addEventListener('click', () => {
        slide.classList.remove('-translate-x-1/2');
    });

    document.getElementById('screeningsListContent').addEventListener('click', (e) => {
        const btn = e.target.closest('.edit-screening-btn');
        if (btn) {
            form.reset();
            form.action = '/employee/screenings/edit';
            formTitle.textContent = 'Edytuj seans';
            document.getElementById('screeningId').value = btn.dataset.id;
            document.getElementById('inputScreeningMovie').value = btn.dataset.movieId;
            document.getElementById('inputScreeningHall').value = btn.dataset.hallId;
            document.getElementById('inputScreeningDate').value = btn.dataset.date + 'T' + btn.dataset.time;
            document.getElementById('inputScreeningCancelled').checked = btn.dataset.cancelled == '1';
            document.getElementById('cancelledGroup').classList.remove('hidden');
            slide.classList.add('-translate-x-1/2');
        }
    });

    const ticketModal = document.getElementById('ticketManagerModal');
    let ticketsPage = 1;
    const TICKETS_PAGE_SIZE = 10;

    function openTicketManager() {
        ticketModal.classList.remove('hidden');
        ticketModal.classList.add('flex');
        ticketsPage = 1;
        loadMoviesForFilter();
        searchTickets();
    }

    function closeTicketManager() {
        ticketModal.classList.add('hidden');
        ticketModal.classList.remove('flex');
    }

    function searchTicketsResetPage() {
        ticketsPage = 1;
        searchTickets();
    }

    function updateTicketsPaginationBar(data) {
        const wrap = document.getElementById('ticketsPaginationWrap');
        const info = document.getElementById('ticketsPaginationInfo');
        const prev = document.getElementById('ticketsPrevPage');
        const next = document.getElementById('ticketsNextPage');
        if (!wrap || !info || !prev || !next) return;

        if (!data || !data.success || data.total === undefined) {
            wrap.classList.add('hidden');
            return;
        }

        if (data.total === 0 || (data.totalPages || 0) < 2) {
            wrap.classList.add('hidden');
            return;
        }

        wrap.classList.remove('hidden');
        info.textContent = `Strona ${data.page} z ${data.totalPages} · ${data.total} wyników`;
        prev.disabled = data.page <= 1;
        next.disabled = data.page >= data.totalPages;
    }

    document.getElementById('ticketsPrevPage')?.addEventListener('click', () => {
        if (ticketsPage > 1) {
            ticketsPage--;
            searchTickets();
        }
    });

    document.getElementById('ticketsNextPage')?.addEventListener('click', () => {
        ticketsPage++;
        searchTickets();
    });

    async function loadMoviesForFilter() {
        const select = document.getElementById('filterMovie');
        if (select.options.length > 1) return;
        try {
            const res = await fetch('/employee/get-movies-list');
            const data = await res.json();
            if (data.success) {
                data.movies.forEach((m) => {
                    const opt = document.createElement('option');
                    opt.value = m.id;
                    opt.innerText = m.title;
                    select.appendChild(opt);
                });
            }
        } catch (e) {
            console.error(e);
        }
    }

    async function searchTickets() {
        const email = document.getElementById('filterEmail').value;
        const movieId = document.getElementById('filterMovie').value;
        const date = document.getElementById('filterDate').value;
        const params = new URLSearchParams({
            email,
            movieId,
            date,
            page: String(ticketsPage),
            limit: String(TICKETS_PAGE_SIZE)
        });
        const tbody = document.getElementById('ticketsTableBody');
        document.getElementById('ticketsPaginationWrap')?.classList.add('hidden');
        tbody.innerHTML = '<tr><td colspan="7" class="p-8 text-center text-base text-stone-500">Ładowanie…</td></tr>';

        try {
            const res = await fetch(`/employee/api/tickets?${params.toString()}`);
            const data = await res.json();
            tbody.innerHTML = '';

            if (!data.success) {
                tbody.innerHTML = '<tr><td colspan="7" class="p-8 text-center text-base font-semibold text-rose-600">Błąd pobierania danych.</td></tr>';
                updateTicketsPaginationBar(null);
                return;
            }

            ticketsPage = data.page || ticketsPage;

            if (data.total === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="p-8 text-center text-base text-stone-500">Brak biletów.</td></tr>';
                updateTicketsPaginationBar(data);
                return;
            }

            if (data.tickets.length === 0 && data.totalPages > 0) {
                ticketsPage = Math.max(1, data.totalPages);
                searchTickets();
                return;
            }

            data.tickets.forEach((t) => {
                const d = new Date(t.date).toLocaleDateString('pl-PL');
                const time = t.time.slice(0, 5);
                const statusColor = t.status === 'cancelled' ? 'text-rose-700' : t.status === 'paid' ? 'text-emerald-700' : 'text-amber-700';
                const isCancellable = t.status !== 'cancelled' && t.status !== 'returned';
                const tr = document.createElement('tr');
                tr.className = 'border-b border-stone-100 transition-colors hover:bg-sky-50/50';
                tr.innerHTML = `
                    <td class="p-3 md:p-4"><span class="font-mono text-sm font-bold text-stone-600">#${t.id}</span></td>
                    <td class="p-3 md:p-4">
                        <span class="text-base font-bold text-stone-900">${t.user_name}</span><br>
                        <span class="text-sm text-stone-500">${t.user_email}</span>
                    </td>
                    <td class="p-3 text-base font-semibold text-stone-800 md:p-4">${t.movie_title}</td>
                    <td class="p-3 text-base md:p-4">${d} <span class="ml-1 inline-flex rounded-full bg-sky-100 px-2.5 py-1 text-xs font-black uppercase text-sky-800">${time}</span></td>
                    <td class="p-3 font-display text-lg font-black text-rose-700 md:p-4">${t.seat_number}</td>
                    <td class="p-3 md:p-4"><span class="text-base font-black uppercase ${statusColor}">${t.status}</span></td>
                    <td class="p-3 md:p-4">
                        ${isCancellable ? `<button type="button" class="rounded-xl bg-gradient-to-r from-amber-500 to-orange-500 px-4 py-2.5 text-base font-black text-white shadow-sm transition hover:from-amber-400 hover:to-orange-400" onclick="refundTicket(${t.id})">Zwróć</button>` : '<span class="text-stone-400">—</span>'}
                    </td>
                `;
                tbody.appendChild(tr);
            });

            updateTicketsPaginationBar(data);
        } catch (err) {
            console.error(err);
            tbody.innerHTML = '<tr><td colspan="7" class="p-8 text-center text-base font-semibold text-rose-600">Błąd pobierania danych.</td></tr>';
            updateTicketsPaginationBar(null);
        }
    }

    function resetTicketFilters() {
        document.getElementById('filterEmail').value = '';
        document.getElementById('filterMovie').value = '';
        document.getElementById('filterDate').value = '';
        ticketsPage = 1;
        searchTickets();
    }

    async function refundTicket(ticketId) {
        if (!confirm(`Czy na pewno chcesz zwrócić bilet #${ticketId}?`)) return;
        try {
            const res = await fetch('/employee/refund-ticket', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ ticketId })
            });
            const data = await res.json();
            if (data.success) {
                alert('Bilet zwrócony.');
                searchTickets();
            } else {
                alert('Błąd: ' + data.message);
            }
        } catch (e) {
            alert('Błąd serwera.');
        }
    }
</script>
