<!DOCTYPE html>
<html lang="pl" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{#if title}}{{title}} | {{/if}}CinemaŚty</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Outfit:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            display: ['Outfit', 'Inter', 'system-ui', 'sans-serif']
          },
          keyframes: {
            fadeIn: { '0%': { opacity: '0' }, '100%': { opacity: '1' } },
            slideUp: { '0%': { opacity: '0', transform: 'translateY(18px)' }, '100%': { opacity: '1', transform: 'translateY(0)' } },
            scaleUp: { '0%': { opacity: '0', transform: 'scale(0.96)' }, '100%': { opacity: '1', transform: 'scale(1)' } },
            blobA: { '0%, 100%': { transform: 'translate(0,0) scale(1)' }, '50%': { transform: 'translate(40px,-30px) scale(1.08)' } },
            blobB: { '0%, 100%': { transform: 'translate(0,0) scale(1)' }, '50%': { transform: 'translate(-35px,25px) scale(1.05)' } },
            blobC: { '0%, 100%': { transform: 'translate(0,0) scale(1)' }, '50%': { transform: 'translate(25px,35px) scale(0.92)' } },
            softPulse: { '0%, 100%': { opacity: '0.35' }, '50%': { opacity: '0.65' } },
            premiereGlow: { '0%, 100%': { opacity: '0.4' }, '50%': { opacity: '0.85' } }
          },
          animation: {
            'fade-in': 'fadeIn 0.55s ease-out forwards',
            'slide-up': 'slideUp 0.55s ease-out forwards',
            'scale-up': 'scaleUp 0.5s ease-out forwards',
            'premiere-glow': 'premiereGlow 2.8s ease-in-out infinite',
            'blob-a': 'blobA 14s ease-in-out infinite',
            'blob-b': 'blobB 11s ease-in-out infinite',
            'blob-c': 'blobC 9s ease-in-out infinite',
            'soft-pulse': 'softPulse 4s ease-in-out infinite'
          }
        }
      },
      safelist: [
        '-translate-x-1/2',
        'text-rose-600',
        'text-emerald-600',
        'text-amber-600',
        'bg-stone-300',
        'hover:bg-stone-400',
        'bg-rose-500',
        'border-stone-200',
        'bg-white',
        'ring-rose-300',
        'ring-2',
        'border-rose-500',
        'bg-rose-50',
        'bg-stone-100',
        'border-stone-300',
        'bg-amber-100',
        'text-rose-700',
        'text-amber-700',
        'ring-rose-200',
        'border-stone-500',
        'bg-stone-700',
        'text-amber-300',
        'ring-rose-400',
        'border-rose-400',
        'bg-rose-500/20',
        'bg-sky-900/80',
        'text-sky-200',
        'border-sky-400',
        'bg-violet-900/80',
        'text-violet-200',
        'border-violet-400',
        'border-stone-600',
        'bg-stone-800',
        'text-stone-500',
        'login-panel',
        'pointer-events-auto',
        'pointer-events-none',
        'translate-x-0',
        '-translate-x-full',
        'translate-x-full',
        'opacity-100',
        'opacity-0',
        'z-10',
        'z-0',
        'z-[100]',
        'absolute',
        'inset-0',
        'transition-all',
        'duration-300',
        'duration-500',
        'ease-out',
        'h-2',
        'w-2',
        'h-2.5',
        'w-8',
        'rounded-full',
        'min-h-96',
        'ring-stone-900/5',
        'animate-premiere-glow',
        'font-display',
        'touch-pan-x',
        'touch-pan-y',
        'overscroll-x-contain'
      ]
    };
  </script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    html {
      font-size: 1rem;
    }

    :root {
      --layout-modal-top: max(5.75rem, env(safe-area-inset-top, 0px));
      --layout-modal-bottom: max(0.5rem, env(safe-area-inset-bottom, 0px));
    }

    @media (min-width: 768px) {
      html {
        font-size: 1.0625rem;
      }

      :root {
        --layout-modal-top: max(9.25rem, env(safe-area-inset-top, 0px));
        --layout-modal-bottom: max(12rem, min(46vh, 28rem));
      }
    }

    .glass-card {
      background: rgba(255, 255, 255, 0.98) !important;
      border: 1px solid rgba(120, 113, 108, 0.2) !important;
      box-shadow: 0 20px 40px -12px rgba(28, 25, 23, 0.12);
    }

    .btn-primary {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 3.35rem;
      padding: 0.9rem 1.85rem;
      border-radius: 0.875rem;
      font-size: 1rem;
      font-weight: 700;
      line-height: 1.25;
      color: #fff;
      background: linear-gradient(135deg, #be123c 0%, #e11d48 40%, #f43f5e 100%);
      box-shadow: 0 4px 20px rgba(225, 29, 72, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.12);
      transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
    }

    .btn-primary:hover {
      transform: translateY(-1px);
      box-shadow: 0 8px 32px rgba(225, 29, 72, 0.5), inset 0 1px 0 rgba(255, 255, 255, 0.15);
      filter: brightness(1.05);
    }

    .btn-primary:active {
      transform: translateY(0) scale(0.98);
    }

    .btn-primary.btn-xl {
      min-height: 3.85rem;
      padding: 1rem 1.85rem;
      font-size: 1.125rem;
      border-radius: 1rem;
    }

    .manager-container .admin-slide-wrap > div {
      -webkit-overflow-scrolling: touch;
    }

    .manager-container .overflow-x-auto {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }
  </style>
</head>
<body class="relative flex min-h-screen flex-col overflow-x-hidden bg-gradient-to-br from-stone-100 via-rose-50/40 to-amber-50/50 font-sans leading-relaxed text-stone-900 antialiased selection:bg-rose-300/50 selection:text-stone-900">
  <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden" aria-hidden="true">
    <div class="absolute -left-24 top-0 h-[22rem] w-[22rem] rounded-full bg-rose-300/35 blur-3xl animate-blob-a"></div>
    <div class="absolute right-0 top-1/4 h-80 w-80 rounded-full bg-amber-200/40 blur-3xl animate-blob-b" style="animation-delay: -3s;"></div>
    <div class="absolute bottom-0 left-1/3 h-96 w-96 rounded-full bg-orange-100/50 blur-3xl animate-blob-c" style="animation-delay: -5s;"></div>
    <div class="absolute bottom-24 right-16 h-72 w-72 rounded-full bg-stone-200/60 blur-3xl animate-soft-pulse"></div>
  </div>

  <div aria-hidden="true" class="pointer-events-none fixed left-0 top-0 -z-20 h-px w-px overflow-hidden opacity-0">
    <span class="login-panel pointer-events-auto absolute inset-0 z-10 translate-x-0 opacity-100 transition-all duration-300 ease-out"></span>
    <span class="login-panel pointer-events-none absolute inset-0 z-0 -translate-x-full opacity-0 transition-all duration-300 ease-out"></span>
    <span class="login-panel pointer-events-none absolute inset-0 z-0 translate-x-full opacity-0 transition-all duration-300 ease-out"></span>
    <span class="h-2 w-2 rounded-full bg-stone-300 transition-all duration-300 hover:bg-stone-400 h-2.5 w-8 bg-rose-500"></span>
  </div>

  {{> header }}
  <main class="relative flex w-full flex-1 flex-col animate-fade-in">
    {{{ body }}}
  </main>
  {{> footer }}
  <script src="/js/main.js"></script>
</body>
</html>
