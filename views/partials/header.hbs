<header class="sticky top-0 z-50 w-full border-b border-stone-600 bg-stone-800 shadow-md shadow-stone-900/20">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-4 md:px-8 md:py-5">
    <a href="/" class="group flex items-center gap-3 transition-transform hover:scale-[1.02] active:scale-95">
      <div class="relative">
        <div class="absolute -inset-2 rounded-2xl bg-rose-500/20 blur-lg transition group-hover:bg-rose-400/30"></div>
        <img src="/images/logoKino.png" alt="CinemaŚty" class="relative h-[4.25rem] w-auto md:h-[5.25rem] lg:h-[5.75rem]">
      </div>
    </a>

    <nav class="hidden items-center gap-1 md:flex">
      <a href="/repertuar" class="rounded-lg px-4 py-3 text-lg font-semibold text-stone-200 transition hover:bg-stone-700/80 hover:text-white">Repertuar</a>
      <a href="/zapowiedzi" class="rounded-lg px-4 py-3 text-lg font-semibold text-stone-200 transition hover:bg-stone-700/80 hover:text-white">Zapowiedzi</a>
      <a href="/cennik" class="rounded-lg px-4 py-3 text-lg font-semibold text-stone-200 transition hover:bg-stone-700/80 hover:text-white">Cennik</a>
      <a href="/kontakt" class="rounded-lg px-4 py-3 text-lg font-semibold text-stone-200 transition hover:bg-stone-700/80 hover:text-white">Kontakt</a>

      <div class="ml-5 flex items-center gap-3">
        {{#if isLoggedIn}}
          {{#if (eq user.role 'user')}}
            <a href="/profil" class="flex min-h-[3.35rem] items-center justify-center gap-2 rounded-xl border border-stone-500 bg-stone-700 px-6 py-3 text-lg font-bold text-stone-100 transition hover:border-stone-400 hover:bg-stone-600 active:scale-[0.98]">
              <i class="fas fa-user text-rose-300"></i> Konto
            </a>
          {{/if}}
          {{#if isAdmin}}
            <a href="/admin" class="flex min-h-[3.35rem] items-center justify-center rounded-xl border border-violet-500/40 bg-stone-700/90 px-6 py-3 text-lg font-bold text-violet-100 shadow-sm ring-1 ring-violet-500/20 transition hover:border-violet-400 hover:bg-stone-600 hover:text-white active:scale-[0.98]">
              Panel Admina
            </a>
          {{/if}}
          {{#if (eq user.role 'employee')}}
            <a href="/employee" class="flex min-h-[3.35rem] items-center justify-center rounded-xl border border-amber-500/40 bg-stone-700/90 px-6 py-3 text-lg font-bold text-amber-100 shadow-sm ring-1 ring-amber-500/20 transition hover:border-amber-400 hover:bg-stone-600 hover:text-amber-50 active:scale-[0.98]">
              Panel Pracownika
            </a>
          {{/if}}
          <a href="/wyloguj" class="flex min-h-[3.35rem] items-center justify-center gap-2 rounded-xl border border-rose-600 bg-rose-600 px-7 py-3 text-lg font-bold text-white shadow-md shadow-rose-950/30 transition hover:border-rose-500 hover:bg-rose-500 hover:shadow-lg hover:shadow-rose-950/25 active:scale-[0.98]">
            <i class="fas fa-right-from-bracket" aria-hidden="true"></i>
            Wyloguj się
          </a>
        {{else}}
          <a href="/logowanie" class="btn-primary flex min-h-[3.35rem] items-center gap-2 px-9 py-3 text-lg">
            Zaloguj się
          </a>
        {{/if}}
      </div>
    </nav>

    <button type="button" id="mobileNavToggle" class="flex h-14 w-14 flex-col items-center justify-center gap-1.5 rounded-xl border border-stone-500 bg-stone-700 transition hover:border-stone-400 hover:bg-stone-600 active:scale-95 md:hidden" aria-label="Menu" aria-expanded="false" aria-controls="mobileNavPanel">
      <div class="h-0.5 w-7 bg-stone-200"></div>
      <div class="h-0.5 w-7 bg-stone-200"></div>
      <div class="h-0.5 w-7 bg-stone-200"></div>
    </button>
  </div>

  <div id="mobileNavRoot" class="fixed inset-0 z-[60] hidden md:hidden" aria-hidden="true">
    <div class="flex h-full w-full justify-end">
      <button type="button" id="mobileNavBackdrop" class="min-h-0 min-w-0 flex-1 cursor-default bg-stone-900/65 transition-opacity" tabindex="-1" aria-label="Zamknij menu"></button>
      <nav id="mobileNavPanel" class="flex h-full max-h-full w-[min(22rem,92vw)] flex-col overflow-y-auto border-l border-stone-600 bg-stone-800 py-6 shadow-2xl shadow-black/40" role="dialog" aria-modal="true" aria-label="Menu nawigacji">
        <div class="flex items-center justify-between border-b border-stone-600 px-5 pb-5">
          <span class="font-display text-lg font-bold text-white">Menu</span>
          <button type="button" id="mobileNavClose" class="flex h-11 w-11 items-center justify-center rounded-xl border border-stone-500 bg-stone-700 text-stone-200 transition hover:border-rose-400/60 hover:bg-stone-600 hover:text-white active:scale-95" aria-label="Zamknij">
            <i class="fas fa-times text-lg" aria-hidden="true"></i>
          </button>
        </div>
        <div class="flex flex-col gap-1 px-3 pt-4">
          <a href="/repertuar" class="mobile-nav-link rounded-xl px-4 py-3.5 text-base font-semibold text-stone-200 transition hover:bg-stone-700 hover:text-white">Repertuar</a>
          <a href="/zapowiedzi" class="mobile-nav-link rounded-xl px-4 py-3.5 text-base font-semibold text-stone-200 transition hover:bg-stone-700 hover:text-white">Zapowiedzi</a>
          <a href="/cennik" class="mobile-nav-link rounded-xl px-4 py-3.5 text-base font-semibold text-stone-200 transition hover:bg-stone-700 hover:text-white">Cennik</a>
          <a href="/kontakt" class="mobile-nav-link rounded-xl px-4 py-3.5 text-base font-semibold text-stone-200 transition hover:bg-stone-700 hover:text-white">Kontakt</a>
        </div>
        <div class="mt-auto flex flex-col gap-3 border-t border-stone-600 p-5">
          {{#if isLoggedIn}}
            {{#if (eq user.role 'user')}}
              <a href="/profil" class="mobile-nav-link flex min-h-[3rem] items-center justify-center gap-2 rounded-xl border border-stone-500 bg-stone-700 px-4 py-3 text-base font-bold text-stone-100 transition hover:border-stone-400 hover:bg-stone-600 active:scale-[0.98]">
                <i class="fas fa-user text-rose-300" aria-hidden="true"></i> Konto
              </a>
            {{/if}}
            {{#if isAdmin}}
              <a href="/admin" class="mobile-nav-link flex min-h-[3rem] items-center justify-center rounded-xl border border-violet-500/40 bg-stone-700/90 px-4 py-3 text-base font-bold text-violet-100 shadow-sm ring-1 ring-violet-500/20 transition hover:border-violet-400 hover:bg-stone-600 hover:text-white active:scale-[0.98]">
                Panel Admina
              </a>
            {{/if}}
            {{#if (eq user.role 'employee')}}
              <a href="/employee" class="mobile-nav-link flex min-h-[3rem] items-center justify-center rounded-xl border border-amber-500/40 bg-stone-700/90 px-4 py-3 text-base font-bold text-amber-100 shadow-sm ring-1 ring-amber-500/20 transition hover:border-amber-400 hover:bg-stone-600 hover:text-amber-50 active:scale-[0.98]">
                Panel Pracownika
              </a>
            {{/if}}
            <a href="/wyloguj" class="mobile-nav-link flex min-h-[3rem] items-center justify-center gap-2 rounded-xl border border-rose-600 bg-rose-600 px-4 py-3 text-base font-bold text-white shadow-md shadow-rose-950/30 transition hover:border-rose-500 hover:bg-rose-500 active:scale-[0.98]">
              <i class="fas fa-right-from-bracket" aria-hidden="true"></i>
              Wyloguj się
            </a>
          {{else}}
            <a href="/logowanie" class="btn-primary mobile-nav-link flex min-h-[3rem] items-center justify-center gap-2 px-6 py-3 text-base">
              Zaloguj się
            </a>
          {{/if}}
        </div>
      </nav>
    </div>
  </div>
</header>
