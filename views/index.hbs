<div class="relative flex-1 overflow-hidden px-4 pb-20 pt-12 md:px-8">
  <div class="relative z-10 mx-auto mb-12 max-w-5xl text-center">
    <h1 class="animate-slide-up text-4xl font-extrabold tracking-tight text-stone-900 md:text-6xl">
      Witaj w <span class="bg-gradient-to-r from-rose-600 to-amber-500 bg-clip-text text-transparent">CinemaŚty</span>
    </h1>
    <p class="animate-slide-up mt-4 text-lg text-stone-600" style="animation-delay: 0.1s">
      Odkryj najnowsze hity i poczuj magię wielkiego ekranu.
    </p>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl">
    {{#if movies.length}}
      <div id="trailerCarousel" class="glass-card relative overflow-hidden rounded-3xl p-2 shadow-xl">
        <div id="carouselTrack" class="flex transition-transform duration-700 cubic-bezier(0.4, 0, 0.2, 1)">
          {{#each movies}}
            <div class="min-w-full shrink-0 group" data-movie-id="{{this.id}}">
              <div class="relative aspect-video overflow-hidden rounded-2xl bg-black transition-transform duration-500 group-hover:scale-[0.99]">
                <iframe
                  class="h-full w-full opacity-90 transition-opacity group-hover:opacity-100"
                  src="https://www.youtube.com/embed/{{this.youtubeId}}?autoplay=0&mute=0&controls=1&loop=0&rel=0&showinfo=0&modestbranding=1&enablejsapi=1"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen>
                </iframe>
                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent p-8">
                   <h2 class="text-2xl font-bold text-white md:text-4xl">{{this.title}}</h2>
                   <div class="mt-2 flex items-center gap-3">
                     <span class="inline-flex items-center gap-1.5 rounded-full border border-rose-400/40 bg-rose-500/25 px-3 py-1 text-xs font-bold uppercase tracking-wider text-rose-100">
                       <i class="fas fa-play text-[10px]"></i> Grają teraz
                     </span>
                     <span class="text-sm font-medium text-slate-200">Premiera tygodnia</span>
                   </div>
                </div>
              </div>
            </div>
          {{/each}}
        </div>

        <div class="pointer-events-none absolute inset-y-0 left-4 right-4 flex items-center justify-between">
          <button type="button" id="prevBtn" class="pointer-events-auto flex h-14 w-14 items-center justify-center rounded-full border border-white/20 bg-black/50 text-white transition-all hover:border-rose-300 hover:bg-rose-600 group/btn" aria-label="Poprzedni">
            <i class="fas fa-chevron-left transition-transform group-hover/btn:-translate-x-1"></i>
          </button>
          <button type="button" id="nextBtn" class="pointer-events-auto flex h-14 w-14 items-center justify-center rounded-full border border-white/20 bg-black/50 text-white transition-all hover:border-rose-300 hover:bg-rose-600 group/btn" aria-label="Następny">
            <i class="fas fa-chevron-right transition-transform group-hover/btn:translate-x-1"></i>
          </button>
        </div>

        <div id="dotsContainer" class="mt-6 flex justify-center gap-3 pb-4">
        </div>
      </div>
    {{else}}
      <div class="glass-card flex flex-col items-center justify-center rounded-3xl py-24 text-center shadow-xl">
        <div class="mb-6 flex h-20 w-20 items-center justify-center rounded-full bg-rose-100 text-rose-400">
          <i class="fas fa-film text-4xl"></i>
        </div>
        <h2 class="text-2xl font-bold text-stone-900 md:text-3xl">Brak aktualnych zwiastunów</h2>
        <p class="mt-4 max-w-md text-stone-600">
          Wróć do nas niebawem! Przebudowujemy repertuar, aby dostarczyć Ci najlepsze kinowe wrażenia.
        </p>
        <a href="/repertuar" class="btn-primary mt-8">Sprawdź seanse</a>
      </div>
    {{/if}}
  </div>
</div>
